    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.39.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "vue": "^3.5.13",
    "vue-markdown-render": "^2.2.1",
    "vue3-apexcharts": "^1.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
